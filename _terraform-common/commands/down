#!/usr/bin/env bash
set -euo pipefail

# Run terraform destroy for a profile's stacks in reverse order.
# Usage: scripts/tf-destroy <instance>

if [ -n "${EVE_INSTANCE_NAME:-}" ]; then
  PROFILE="$EVE_INSTANCE_NAME"
else
  PROFILE="${1:?Usage: commands/down <instance>}"
fi
cd "$(git rev-parse --show-toplevel)"

RESOLVED_ENV=$(./scripts/profile-resolve --profile "$PROFILE" --emit env)
ENGINE=$(printf "%s\n" "$RESOLVED_ENV" | awk -F= '/^ENGINE=/{print $2}')

if [ "$ENGINE" != "terraform" ]; then
  echo "Error: $PROFILE uses engine '$ENGINE', not terraform" >&2
  exit 1
fi

TAGS=$(printf "%s\n" "$RESOLVED_ENV" | awk -F= '/^STACK_TAGS=/{print $2}')
echo "[tf-destroy] profile=$PROFILE tags=$TAGS"

TM_RUN_FLAGS=(
  --disable-safeguards=git-untracked
  --disable-safeguards=git-uncommitted
  --disable-safeguards=git-out-of-sync
  --disable-safeguards=outdated-code
)

terramate generate

eval "$(./scripts/tf-env "$PROFILE")"

# Initialize the backend before destroy, mirroring `up`. Without this, a stack
# whose .terraform backend isn't initialized (fresh checkout, cleaned cache,
# regenerated backend config) fails destroy with "Backend initialization
# required" instead of tearing the instance down.
if [ -n "${EVE_INSTANCE_NAME:-}" ]; then
  echo "[tf-destroy] instance=$EVE_INSTANCE_NAME initializing backend before destroy"
  "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/init" "$PROFILE"
fi

terramate run "${TM_RUN_FLAGS[@]}" --tags="$TAGS" --reverse -- terraform destroy -auto-approve
