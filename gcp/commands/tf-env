#!/usr/bin/env python3
from __future__ import annotations

import os
import shutil
import subprocess
import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parents[4]
sys.path.insert(0, str(ROOT))

from eve_sdk.tf_env import load_env, print_kv  # noqa: E402

env = load_env()
project_id = os.environ.get("GOOGLE_CLOUD_PROJECT") or os.environ.get("GOOGLE_PROJECT") or ""
if not project_id and shutil.which("gcloud"):
    result = subprocess.run(["gcloud", "config", "get-value", "project"], text=True, capture_output=True, check=False)
    if result.returncode == 0:
        project_id = result.stdout.strip()
if not project_id:
    print("tf-env: missing GOOGLE_CLOUD_PROJECT or GOOGLE_PROJECT for gcp provider", file=sys.stderr)
    raise SystemExit(2)

print_kv("TF_VAR_disk_gb", env.get("VM_DISK_GB", ""))
print_kv("TF_VAR_disk_type", env.get("VM_DISK_TYPE", ""))
print_kv("TF_VAR_image_family", env.get("GCP_IMAGE_FAMILY", ""))
print_kv("TF_VAR_image_project", env.get("GCP_IMAGE_PROJECT", ""))
print_kv("TF_VAR_machine_type", env.get("VM_MACHINE_TYPE", ""))
print_kv("TF_VAR_project_id", project_id)
print_kv("TF_VAR_region", env.get("LOCATION_REGION", ""))

my_ip = os.environ.get("MY_IP", "")
if not my_ip:
    print("tf-env: missing MY_IP for gcp provider", file=sys.stderr)
    raise SystemExit(2)
print_kv("TF_VAR_ssh_allowed_cidr", f"{my_ip}/32")
print_kv("TF_VAR_zone", env.get("LOCATION_ZONE", ""))
