#!/usr/bin/env bash
# Raspberry Pi metal SSH. Supplies HostKeyAlias when the resolved IP
# differs from the configured hostname so host-key changes don't trip
# StrictHostKeyChecking after the Pi's address moves.
#
# Usage:
#   commands/ssh <instance>                         # interactive shell
#   commands/ssh <instance> -- <cmd> [args...]      # remote command
#   commands/ssh <instance> --scp <local> <remote>  # scp helper

set -euo pipefail

if [ -n "${EVE_INSTANCE_NAME:-}" ]; then
  PROFILE="$EVE_INSTANCE_NAME"
else
  PROFILE="${1:?Usage: commands/ssh <instance> [-- <cmd>] [--scp <local> <remote>]}"
  shift || true
fi
cd "$(git rev-parse --show-toplevel)"
# shellcheck source=scripts/lib/load-runtime-env.sh
. ./scripts/lib/load-runtime-env.sh
# shellcheck source=scripts/lib/instance-workdir.sh
. ./scripts/lib/instance-workdir.sh
# shellcheck source=plugins/providers/_common/lib/profile-env.sh
. ./plugins/providers/_common/lib/profile-env.sh
# shellcheck source=plugins/providers/_common/lib/ssh-helpers.sh
. ./plugins/providers/_common/lib/ssh-helpers.sh

eve_load_profile_env "$PROFILE"
./scripts/env-require VM_USER_NAME

RESOLVED_PI_HOST=$(eve_resolved_value RASPBERRY_PI_HOST)
RESOLVED_PI_IP=$(eve_resolved_value RASPBERRY_PI_IP)

if [ -n "$RESOLVED_PI_IP" ]; then
  IP="$RESOLVED_PI_IP"
else
  IP=$(./scripts/instance-ip "$PROFILE")
fi
[ -n "$IP" ] || { echo "instance-ssh: could not resolve IP for $PROFILE" >&2; exit 1; }

PI_SSH_USER="${SSH_USER:-$VM_USER_NAME}"

WORKDIR="$(eve_instance_workdir "$PROFILE")"
mkdir -p "$WORKDIR/ssh"
KNOWN_HOSTS_FILE="$WORKDIR/ssh/known_hosts"

PRIV_KEY="$(eve_resolve_priv_key)"

SSH_OPTS=()
while IFS= read -r opt; do
  SSH_OPTS+=("$opt")
done < <(eve_default_ssh_opts "$KNOWN_HOSTS_FILE")
[ -n "$PRIV_KEY" ] && SSH_OPTS+=(-i "$PRIV_KEY" -o IdentitiesOnly=yes)
if [ -n "$RESOLVED_PI_HOST" ] && [ "$IP" != "$RESOLVED_PI_HOST" ]; then
  SSH_OPTS+=(-o "HostKeyAlias=$RESOLVED_PI_HOST")
fi

if [ "${1:-}" = "--scp" ]; then
  shift
  LOCAL_PATH="${1:?--scp requires <local> <remote>}"
  REMOTE_PATH="${2:?--scp requires <local> <remote>}"
  exec scp "${SSH_OPTS[@]}" -r "$LOCAL_PATH" "$PI_SSH_USER@$IP:$REMOTE_PATH"
fi

if [ "${1:-}" = "--" ]; then
  shift
  exec ssh "${SSH_OPTS[@]}" "$PI_SSH_USER@$IP" "$@"
fi

exec ssh "${SSH_OPTS[@]}" "$PI_SSH_USER@$IP"
