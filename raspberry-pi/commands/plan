#!/usr/bin/env python3
from __future__ import annotations

import os
import subprocess
import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parents[4]
instance = os.environ.get("EVE_INSTANCE_NAME") or (sys.argv[1] if len(sys.argv) > 1 else "")
if not instance:
    print("Usage: commands/plan <instance>", file=sys.stderr)
    raise SystemExit(2)

print(f"[plan] instance={instance} uses metal hardware; provisioning will run over SSH.", file=sys.stderr)
result = subprocess.run([str(ROOT / "scripts/profile-resolve"), "--profile", instance, "--emit", "env"], check=False)
raise SystemExit(result.returncode)
