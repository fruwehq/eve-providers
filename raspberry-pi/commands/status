#!/usr/bin/env bash
# Report Raspberry Pi (metal) reachability.
set -euo pipefail

if [ -n "${EVE_INSTANCE_NAME:-}" ]; then
  PROFILE="$EVE_INSTANCE_NAME"
else
  PROFILE="${1:?Usage: commands/status <instance>}"
fi
cd "$(git rev-parse --show-toplevel)"
# shellcheck source=plugins/providers/_common/lib/profile-env.sh
. ./plugins/providers/_common/lib/profile-env.sh

eve_load_profile_env "$PROFILE"

printf '%-15s %s\n' "Profile:" "$PROFILE"
printf '%-15s %s\n' "Engine:" "$ENGINE"
printf '%-15s %s\n' "Provider:" "$PROVIDER"
printf '%-15s %s\n' "OS:" "$OS_FAMILY"

IP=$(./scripts/instance-ip "$PROFILE" 2>/dev/null || true)
if [ -n "$IP" ]; then
  printf '%-15s %s\n' "IP:" "$IP"
fi
if ./scripts/instance-ssh "$PROFILE" -- exit 0 >/dev/null 2>&1; then
  VM_STATUS="running"
else
  VM_STATUS="unreachable"
fi
printf '%-15s %s\n' "Status:" "$VM_STATUS"
