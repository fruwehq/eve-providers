#!/usr/bin/env python3
from __future__ import annotations

import os
import sys

instance = os.environ.get("EVE_INSTANCE_NAME") or (sys.argv[1] if len(sys.argv) > 1 else "")
if not instance:
    print("Usage: commands/up <instance>", file=sys.stderr)
    raise SystemExit(2)

print(f"[up] instance={instance} uses metal hardware; nothing to create.", file=sys.stderr)
