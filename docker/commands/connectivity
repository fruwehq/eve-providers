#!/usr/bin/env python3
"""Docker connectivity probe for providers-status."""
from __future__ import annotations

import json
import shutil


def main() -> None:
    if shutil.which("docker"):
        print(json.dumps({"configured": "yes", "reachable": "yes", "notes": "docker available"}))
    else:
        print(json.dumps({"configured": "no", "reachable": "no", "notes": "docker not found"}))


if __name__ == "__main__":
    main()
