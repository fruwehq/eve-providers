#!/usr/bin/env python3
from __future__ import annotations

import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parents[4]
sys.path.insert(0, str(ROOT))

from eve_sdk.tf_env import load_env, print_kv  # noqa: E402

env = load_env()
print_kv("TF_VAR_availability_zone", env.get("LOCATION_AVAILABILITY_ZONE", ""))
print_kv("TF_VAR_disk_gb", env.get("VM_DISK_GB", ""))
print_kv("TF_VAR_instance_type", env.get("VM_INSTANCE_TYPE", ""))
print_kv("TF_VAR_region", env.get("LOCATION_REGION", ""))
print_kv("TF_VAR_root_volume_type", env.get("VM_ROOT_VOLUME_TYPE", ""))
print_kv("TF_VAR_use_spot", env.get("VM_USE_SPOT", ""))
