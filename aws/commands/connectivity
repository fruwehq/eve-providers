#!/usr/bin/env python3
"""AWS connectivity probe for providers-status."""
from __future__ import annotations

import json
import os
import shutil
import subprocess

_DEVNULL = subprocess.DEVNULL


def main() -> None:
    configured = "no"
    reachable = "no"

    if shutil.which("aws") is None:
        print(json.dumps({"configured": configured, "reachable": reachable, "notes": "aws cli not found"}))
        return

    args = ["sts", "get-caller-identity"]
    aws_profile = os.environ.get("AWS_PROFILE", "")
    aws_region = os.environ.get("AWS_REGION", "")
    if aws_profile:
        args = ["--profile", aws_profile, *args]
    if aws_region:
        args = ["--region", aws_region, *args]

    if subprocess.run(["aws", *args], stdout=_DEVNULL, stderr=_DEVNULL, check=False).returncode == 0:
        suffix = f" (profile {aws_profile})" if aws_profile else ""
        print(json.dumps({"configured": "yes", "reachable": "yes", "notes": f"aws sts ok{suffix}"}))
        return
    if aws_profile or os.environ.get("AWS_ACCESS_KEY_ID", ""):
        print(json.dumps({"configured": "yes", "reachable": "no",
                          "notes": "configured but aws sts failed - run the AWS Login provider action "
                                   "(SSO session may be expired)"}))
        return
    print(json.dumps({"configured": "no", "reachable": "no",
                      "notes": "no working AWS credentials; run AWS Login (SSO) or set aws.profile in settings"}))


if __name__ == "__main__":
    main()
