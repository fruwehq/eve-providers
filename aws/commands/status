#!/usr/bin/env bash
# Report AWS EC2 instance status.
set -euo pipefail

if [ -n "${EVE_INSTANCE_NAME:-}" ]; then
  PROFILE="$EVE_INSTANCE_NAME"
else
  PROFILE="${1:?Usage: commands/status <instance>}"
fi
cd "$(git rev-parse --show-toplevel)"
# shellcheck source=plugins/providers/_common/lib/profile-env.sh
. ./plugins/providers/_common/lib/profile-env.sh
# shellcheck source=plugins/providers/_common/lib/tf-state.sh
. ./plugins/providers/_common/lib/tf-state.sh

eve_load_profile_env "$PROFILE"

printf '%-15s %s\n' "Profile:" "$PROFILE"
printf '%-15s %s\n' "Engine:" "$ENGINE"
printf '%-15s %s\n' "Provider:" "$PROVIDER"
printf '%-15s %s\n' "OS:" "$OS_FAMILY"

eval "$(./scripts/tf-env "$PROFILE")"
STATE_JSON=$(eve_tf_state_json "$TAGS" \
  "plugins/providers/${PROVIDER}/stacks/20-services" \
  "stacks/${PROVIDER}/20-services")

if [ -z "$STATE_JSON" ]; then
  VM_STATUS="not created"
else
  RAW=$(eve_tf_attr "$STATE_JSON" "aws_instance.main" "instance_state")
  # instance_state in terraform state is the last-applied value and is not
  # refreshed, so a spot-reclaimed or out-of-band-terminated instance still
  # reads "running" here. Verify the tracked instance against live AWS.
  INSTANCE_ID=$(eve_tf_attr "$STATE_JSON" "aws_instance.main" "id")
  if [ -n "$INSTANCE_ID" ] && command -v aws >/dev/null 2>&1; then
    LIVE=$(aws ec2 describe-instances --instance-ids "$INSTANCE_ID" \
      ${AWS_PROFILE:+--profile "$AWS_PROFILE"} ${AWS_REGION:+--region "$AWS_REGION"} \
      --query 'Reservations[].Instances[].State.Name' --output text 2>/dev/null || true)
    # Empty result = the instance no longer exists (terminated and aged out).
    RAW="${LIVE:-terminated}"
  fi
  case "$RAW" in
    "") VM_STATUS="not created" ;;
    stopped) VM_STATUS="$RAW" ;;
    terminated|shutting-down) VM_STATUS="absent" ;;
    *) VM_STATUS="$RAW" ;;
  esac

  if [ "$VM_STATUS" = "running" ]; then
    IP=$(./scripts/instance-ip "$PROFILE" 2>/dev/null || true)
    if [ -n "$IP" ]; then
      printf '%-15s %s\n' "IP:" "$IP"
    fi
  fi
fi

printf '%-15s %s\n' "Status:" "$VM_STATUS"
