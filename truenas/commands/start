#!/usr/bin/env bash
# Power on a TrueNAS VM via midclt over SSH to the NAS host.
set -euo pipefail

if [ -n "${EVE_INSTANCE_NAME:-}" ]; then
  PROFILE="$EVE_INSTANCE_NAME"
else
  PROFILE="${1:?Usage: commands/start <instance>}"
fi
cd "$(git rev-parse --show-toplevel)"
# shellcheck source=plugins/providers/_common/lib/profile-env.sh
. ./plugins/providers/_common/lib/profile-env.sh
# shellcheck source=plugins/providers/_common/lib/tf-state.sh
. ./plugins/providers/_common/lib/tf-state.sh
# shellcheck source=plugins/providers/truenas/lib/truenas-host.sh
. ./plugins/providers/truenas/lib/truenas-host.sh

eve_load_profile_env "$PROFILE"
eval "$(./scripts/tf-env "$PROFILE")"

STATE_JSON=$(eve_tf_state_json "$TAGS" \
  "plugins/providers/truenas/stacks/truenas/20-services" \
  "stacks/truenas/20-services")
if [ -z "$STATE_JSON" ]; then
  echo "[start] No instance in state. Run 'make up INSTANCE=$PROFILE' first." >&2
  exit 1
fi

./scripts/env-require TRUENAS_SSH_USER
VM_ID=$(eve_tf_attr "$STATE_JSON" "truenas_vm.this" "id")
VM_NAME=$(eve_tf_attr "$STATE_JSON" "truenas_vm.this" "name")
if [ -z "$VM_ID" ]; then
  echo "[start] TrueNAS VM id not found in state." >&2
  exit 1
fi

LIVE_STATE=$(truenas_vm_state "$VM_ID" || true)
if [ "$(printf '%s' "$LIVE_STATE" | tr '[:lower:]' '[:upper:]')" = "RUNNING" ]; then
  echo "[start] Already running"
  exit 0
fi

echo "[start] Starting TrueNAS VM $VM_NAME (id=$VM_ID)"
truenas_ssh_opts
# shellcheck disable=SC2029
ssh "${TRUENAS_SSH_OPTS[@]}" "${TRUENAS_SSH_USER_RESOLVED}@${TRUENAS_HOST}" "sudo midclt call vm.start $VM_ID"
echo "[start] VM start initiated"

terramate run --quiet --tags="$TAGS-services" -- terraform refresh 2>/dev/null || true
