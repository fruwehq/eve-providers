#!/usr/bin/env bash
# Verify that a ZFS dataset exists on TrueNAS.
# Uses the same SSH credentials as the Terraform truenas provider.
# This is a one-time setup requirement — see README.
#
# Usage: scripts/truenas-dataset-verify <mount_path>
#
# Example: truenas-dataset-verify /mnt/pool1/eve
#   Verifies: pool1/eve exists as a ZFS dataset.

set -euo pipefail

MOUNT_PATH="${1:?Usage: truenas-dataset-verify <mount_path>}"
DATASET="${MOUNT_PATH#/mnt/}"

normalize_path() {
  local value="$1"
  # shellcheck disable=SC2088,SC2016
  case "$value" in
    '~'|'~/'*)
      printf '%s' "$HOME${value#\~}"
      ;;
    '$HOME'|'$HOME/'*)
      printf '%s' "$HOME${value#\$HOME}"
      ;;
    '$(HOME)'|'$(HOME)/'*)
      printf '%s' "$HOME${value#\$\(HOME\)}"
      ;;
    *)
      printf '%s' "$value"
      ;;
  esac
}

SSH_USER="${TRUENAS_SSH_USER:-terraform}"
SSH_OPTS=(-o StrictHostKeyChecking=no -o IdentitiesOnly=yes)
if [ -n "${TRUENAS_SSH_PRIVATE_KEY_FILE:-}" ]; then
  SSH_KEY="$(normalize_path "${TRUENAS_SSH_PRIVATE_KEY_FILE}")"
  if [ ! -f "${SSH_KEY}" ]; then
    SSH_KEY="${HOME}${SSH_KEY}"
  fi
  SSH_OPTS+=(-i "${SSH_KEY}")
fi
if [ -n "${TRUENAS_SSH_PORT:-}" ]; then
  SSH_OPTS+=(-p "${TRUENAS_SSH_PORT}")
fi

HOST="${TRUENAS_HOST:?TRUENAS_HOST must be set}"

# shellcheck disable=SC2029
if ! ssh "${SSH_OPTS[@]}" "${SSH_USER}@${HOST}" "midclt call pool.dataset.query | jq -e '.[].name | select(. == \"${DATASET}\")' >/dev/null 2>&1"; then
  echo "ERROR: Dataset ${DATASET} does not exist on ${HOST}." >&2
  echo "Create it with:  midclt call pool.dataset.create '{\"name\": \"${DATASET}\"}'" >&2
  echo "Or via the TrueNAS web UI under Storage > Pools." >&2
  exit 1
fi

echo "[truenas-dataset-verify] ${DATASET} exists."
