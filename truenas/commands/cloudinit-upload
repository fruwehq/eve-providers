#!/usr/bin/env bash
set -euo pipefail

# Generate a NoCloud cloud-init seed ISO and upload it to TrueNAS via SCP.
# Usage: truenas-cloudinit-upload <vm_name> <ssh_public_key_file> <truenas_host> <iso_path> <provision_user_name> [human_user_name]

VM_NAME="${1:?vm_name required}"
SSH_PUBLIC_KEY_FILE="${2:?ssh_public_key_file required}"
TRUENAS_HOST="${3:?truenas_host required}"
ISO_PATH="${4:?iso_path required}"
PROVISION_USER_NAME="${5:-}"
HUMAN_USER_NAME="${6:-}"
if [ -z "$PROVISION_USER_NAME" ]; then
  echo "truenas-cloudinit-upload: provision_user_name is required" >&2
  exit 2
fi
validate_user_name() {
  local label="$1"
  local value="$2"
  case "$value" in
    *[!a-zA-Z0-9._-]*)
      echo "truenas-cloudinit-upload: $label contains unsupported characters: $value" >&2
      exit 2
      ;;
  esac
}
validate_user_name provision_user_name "$PROVISION_USER_NAME"
if [ -n "$HUMAN_USER_NAME" ]; then
  validate_user_name human_user_name "$HUMAN_USER_NAME"
fi

normalize_path() {
  local value="$1"
  # shellcheck disable=SC2088,SC2016
  case "$value" in
    '~'|'~/'*)
      printf '%s' "$HOME${value#\~}"
      ;;
    '$HOME'|'$HOME/'*)
      printf '%s' "$HOME${value#\$HOME}"
      ;;
    '$(HOME)'|'$(HOME)/'*)
      printf '%s' "$HOME${value#\$\(HOME\)}"
      ;;
    *)
      printf '%s' "$value"
      ;;
  esac
}

SSH_USER="${TRUENAS_SSH_USER:-terraform}"
SSH_OPTS=(-o StrictHostKeyChecking=no -o IdentitiesOnly=yes)
if [ -n "${TRUENAS_SSH_PRIVATE_KEY_FILE:-}" ]; then
  SSH_KEY="$(normalize_path "${TRUENAS_SSH_PRIVATE_KEY_FILE}")"
  if [ ! -f "${SSH_KEY}" ]; then
    SSH_KEY="${HOME}${SSH_KEY}"
  fi
  SSH_OPTS+=(-i "${SSH_KEY}")
fi
if [ -n "${TRUENAS_SSH_PORT:-}" ] && [ "${TRUENAS_SSH_PORT}" != "22" ]; then
  SSH_OPTS+=(-p "${TRUENAS_SSH_PORT}")
fi

SSH_PUBLIC_KEY=$(cat "$SSH_PUBLIC_KEY_FILE")

TMPDIR=$(mktemp -d)
trap 'rm -rf "$TMPDIR"' EXIT

mkdir -p "$TMPDIR/cidata"

cat > "$TMPDIR/cidata/user-data" <<EOF
#cloud-config
hostname: $VM_NAME
users:
  - name: $PROVISION_USER_NAME
    lock_passwd: true
    ssh_authorized_keys:
      - $SSH_PUBLIC_KEY
    sudo:
      - ALL=(ALL) NOPASSWD:ALL
    shell: /bin/bash
    groups: [adm, sudo]
EOF

if [ -n "$HUMAN_USER_NAME" ] && [ "$HUMAN_USER_NAME" != "$PROVISION_USER_NAME" ]; then
  cat >> "$TMPDIR/cidata/user-data" <<EOF
  - name: $HUMAN_USER_NAME
    lock_passwd: true
    ssh_authorized_keys:
      - $SSH_PUBLIC_KEY
    shell: /bin/bash
    groups: [adm, sudo]
EOF
fi

cat > "$TMPDIR/cidata/meta-data" <<EOF
instance-id: $VM_NAME
local-hostname: $VM_NAME
EOF

hdiutil makehybrid \
  -o "$TMPDIR/cidata.iso" \
  -hfs -joliet -iso \
  -default-volume-name cidata \
  "$TMPDIR/cidata" \
  >/dev/null

# shellcheck disable=SC2029
ssh "${SSH_OPTS[@]}" "${SSH_USER}@${TRUENAS_HOST}" "mkdir -p '$(dirname "$ISO_PATH")'"
scp "${SSH_OPTS[@]}" "$TMPDIR/cidata.iso" "${SSH_USER}@${TRUENAS_HOST}:${ISO_PATH}"

printf '[truenas-cloudinit-upload] %s -> %s\n' "$VM_NAME" "$ISO_PATH"
