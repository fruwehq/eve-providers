#!/usr/bin/env bash
# Prepare a VM disk image on TrueNAS.
#
# Downloads the cloud image directly on the NAS (cached in images/),
# converts to raw if needed (qcow2 → raw), then writes to the zvol
# via sudo dd.
#
# Requires sudoers entry for dd (see README).
#
# Usage: scripts/truenas-vm-disk-prepare \
#          <host> <images_dir> <zvol_device> <vm_name> <cloud_image_url> <disk_gb>

set -euo pipefail

HOST="${1:?Usage: truenas-vm-disk-prepare <host> <images_dir> <zvol_device> <vm_name> <cloud_image_url> <disk_gb>}"
IMAGES_DIR="${2:?}"
ZVOL_DEVICE="${3:?}"
_="${4:?}" # vm_name (reserved for future use)
IMAGE_URL="${5:?}"
_="${6:?}" # disk_gb (reserved for future use, zvol sized by terraform)

normalize_path() {
  local value="$1"
  # shellcheck disable=SC2088,SC2016
  case "$value" in
    '~'|'~/'*)
      printf '%s' "$HOME${value#\~}"
      ;;
    '$HOME'|'$HOME/'*)
      printf '%s' "$HOME${value#\$HOME}"
      ;;
    '$(HOME)'|'$(HOME)/'*)
      printf '%s' "$HOME${value#\$\(HOME\)}"
      ;;
    *)
      printf '%s' "$value"
      ;;
  esac
}

SSH_USER="${TRUENAS_SSH_USER:-terraform}"
SSH_OPTS=(-o StrictHostKeyChecking=no -o IdentitiesOnly=yes)
if [ -n "${TRUENAS_SSH_PRIVATE_KEY_FILE:-}" ]; then
  SSH_KEY="$(normalize_path "${TRUENAS_SSH_PRIVATE_KEY_FILE}")"
  if [ ! -f "${SSH_KEY}" ]; then
    SSH_KEY="${HOME}${SSH_KEY}"
  fi
  SSH_OPTS+=(-i "${SSH_KEY}")
fi
if [ -n "${TRUENAS_SSH_PORT:-}" ] && [ "${TRUENAS_SSH_PORT}" != "22" ]; then
  SSH_OPTS+=(-p "${TRUENAS_SSH_PORT}")
fi

# shellcheck disable=SC2029
ssh_cmd() { ssh "${SSH_OPTS[@]}" "${SSH_USER}@${HOST}" "$@"; }

IMAGE_FILENAME="$(basename "$IMAGE_URL")"
REMOTE_IMAGE="${IMAGES_DIR}/${IMAGE_FILENAME}"
RAW_IMAGE="${REMOTE_IMAGE%.img}.raw"
# Handle filenames that don't end in .img
if [ "${RAW_IMAGE}" = "${REMOTE_IMAGE}" ]; then
  RAW_IMAGE="${REMOTE_IMAGE}.raw"
fi

# Ensure images directory exists
ssh_cmd "mkdir -p '${IMAGES_DIR}'"

# Download base image directly on NAS if not cached
if ! ssh_cmd "test -f '${REMOTE_IMAGE}'" 2>/dev/null; then
  echo "[truenas-vm-disk-prepare] Downloading ${IMAGE_URL} directly to NAS..."
  ssh_cmd "curl -fL -o '${REMOTE_IMAGE}' '${IMAGE_URL}'"
else
  echo "[truenas-vm-disk-prepare] Base image already cached on NAS."
fi

# Convert to raw if needed (detect format via magic bytes)
IMAGE_FORMAT="$(ssh_cmd "file -b '${REMOTE_IMAGE}' | head -1")"
if echo "$IMAGE_FORMAT" | grep -qi "qemu\|qcow"; then
  echo "[truenas-vm-disk-prepare] Converting qcow2 to raw..."
  ssh_cmd "qemu-img convert -f qcow2 -O raw '${REMOTE_IMAGE}' '${RAW_IMAGE}'"
  DD_INPUT="${RAW_IMAGE}"
else
  DD_INPUT="${REMOTE_IMAGE}"
fi

# Write raw image to zvol via sudo dd
echo "[truenas-vm-disk-prepare] Writing image to ${ZVOL_DEVICE}..."
ssh_cmd "sudo dd if='${DD_INPUT}' of='${ZVOL_DEVICE}' bs=4M status=progress"

echo "[truenas-vm-disk-prepare] Done."
