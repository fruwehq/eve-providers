#!/usr/bin/env bash
# Resolve a TrueNAS VM's IP by ARP-matching on the NAS, then SSH-probing
# candidate IPs for the expected hostname.
set -euo pipefail

if [ -n "${EVE_INSTANCE_NAME:-}" ]; then
  PROFILE="$EVE_INSTANCE_NAME"
else
  PROFILE="${1:?Usage: commands/ip <instance>}"
fi
cd "$(git rev-parse --show-toplevel)"
# shellcheck source=scripts/lib/load-runtime-env.sh
. ./scripts/lib/load-runtime-env.sh
# shellcheck source=plugins/providers/_common/lib/profile-env.sh
. ./plugins/providers/_common/lib/profile-env.sh
# shellcheck source=plugins/providers/_common/lib/tf-state.sh
. ./plugins/providers/_common/lib/tf-state.sh

eve_load_profile_env "$PROFILE"
eval "$(./scripts/tf-env "$PROFILE")"

./scripts/env-require TRUENAS_SSH_USER
RESOLVED_TRUENAS_HOST=$(eve_resolved_value TRUENAS_HOST)
RESOLVED_TRUENAS_SSH_PORT=$(eve_resolved_value TRUENAS_SSH_PORT)
RESOLVED_TRUENAS_SSH_USER=$(eve_resolved_value TRUENAS_SSH_USER)

VM_NAME=$(terramate run "${EVE_TM_READ_FLAGS[@]}" --quiet --tags="$TAGS-services" -- terraform output -raw truenas_vm_name)
NAS_USER="${TRUENAS_SSH_USER:-$RESOLVED_TRUENAS_SSH_USER}"
NAS_HOST="${TRUENAS_HOST:-$RESOLVED_TRUENAS_HOST}"
if [ -z "$NAS_HOST" ]; then
  echo "instance-ip: missing TrueNAS host for profile '$PROFILE'" >&2
  exit 2
fi
SSH_KEY="${TRUENAS_SSH_PRIVATE_KEY_FILE:-}"
SSH_KEY="$(eve_normalize_path "$SSH_KEY")"
NAS_OPTS=(-o StrictHostKeyChecking=no -o IdentitiesOnly=yes)
[ -n "$SSH_KEY" ] && NAS_OPTS+=(-i "$SSH_KEY")
SSH_PORT="${TRUENAS_SSH_PORT:-$RESOLVED_TRUENAS_SSH_PORT}"
[ -n "$SSH_PORT" ] && [ "$SSH_PORT" != "22" ] && NAS_OPTS+=(-p "$SSH_PORT")

# TrueNAS auto-generates NIC MACs but does not expose them in Terraform or
# vm.device.query. Match the VM by its cloud-init hostname instead.
CANDIDATES=$(ssh "${NAS_OPTS[@]}" "${NAS_USER}@${NAS_HOST}" \
  "awk '/br0/ && /00:a0:98/ {print \$1}' /proc/net/arp")
if [ -z "$CANDIDATES" ]; then
  echo "instance-ip: no TrueNAS VM ARP candidates found" >&2
  exit 2
fi

VM_SSH_OPTS=(-o StrictHostKeyChecking=no -o IdentitiesOnly=yes -o BatchMode=yes -o ConnectTimeout=1)
VM_KEY_FILE="${SSH_PUBLIC_KEY_FILE:-}"
VM_KEY_FILE="$(eve_normalize_path "$VM_KEY_FILE")"
[ -n "$VM_KEY_FILE" ] && VM_SSH_KEY="${VM_KEY_FILE%.pub}" && VM_SSH_OPTS+=(-i "$VM_SSH_KEY")

FOUND=""
for IP in $CANDIDATES; do
  [ -n "$SSH_USER" ] || continue
  HOSTNAME=$(ssh "${VM_SSH_OPTS[@]}" "${SSH_USER}@${IP}" hostname 2>/dev/null) || continue
  if [ "$HOSTNAME" = "$VM_NAME" ]; then
    FOUND="$IP"
    break
  fi
done
if [ -z "$FOUND" ]; then
  echo "instance-ip: no TrueNAS ARP candidate matched hostname '$VM_NAME'" >&2
  exit 2
fi
printf '%s\n' "$FOUND"
