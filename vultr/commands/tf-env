#!/usr/bin/env python3
from __future__ import annotations

import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parents[4]
sys.path.insert(0, str(ROOT))

from eve_sdk.tf_env import load_env, print_kv  # noqa: E402

env = load_env()
print_kv("TF_VAR_plan", env.get("VM_PLAN", ""))
print_kv("TF_VAR_region", env.get("LOCATION_REGION", ""))
print_kv("TF_VAR_vultr_os_id", env.get("VULTR_OS_ID", ""))
