#!/usr/bin/env bash
# Power on a Vultr instance via the Vultr REST API.
set -euo pipefail

if [ -n "${EVE_INSTANCE_NAME:-}" ]; then
  PROFILE="$EVE_INSTANCE_NAME"
else
  PROFILE="${1:?Usage: commands/start <instance>}"
fi
cd "$(git rev-parse --show-toplevel)"
# shellcheck source=plugins/providers/_common/lib/profile-env.sh
. ./plugins/providers/_common/lib/profile-env.sh
# shellcheck source=plugins/providers/_common/lib/tf-state.sh
. ./plugins/providers/_common/lib/tf-state.sh

eve_load_profile_env "$PROFILE"
eval "$(./scripts/tf-env "$PROFILE")"

STATE_JSON=$(eve_tf_state_json "$TAGS" \
  "plugins/providers/${PROVIDER}/stacks/20-services" \
  "stacks/${PROVIDER}/20-services")
if [ -z "$STATE_JSON" ]; then
  echo "[start] No instance in state. Run 'make up INSTANCE=$PROFILE' first." >&2
  exit 1
fi

RAW=$(eve_tf_attr "$STATE_JSON" "vultr_instance.default" "power_status")
if [ "$RAW" = "running" ]; then
  echo "[start] Already running"
  exit 0
fi

INSTANCE_ID=$(terramate run --quiet --tags="$TAGS-services" -- terraform output -raw instance_id)
echo "[start] Starting Vultr instance $INSTANCE_ID"
HTTP_CODE=$(curl -s -o /dev/null -w "%{http_code}" -X POST \
  -H "Authorization: Bearer ${VULTR_API_KEY}" \
  "https://api.vultr.com/v2/instances/$INSTANCE_ID/start")
if [ "$HTTP_CODE" -ge 200 ] && [ "$HTTP_CODE" -lt 300 ]; then
  echo "[start] Instance start initiated (HTTP $HTTP_CODE)"
else
  echo "[start] Failed to start instance (HTTP $HTTP_CODE)" >&2
  exit 1
fi

terramate run --quiet --tags="$TAGS-services" -- terraform refresh 2>/dev/null || true
