#!/usr/bin/env python3
"""Validate provider-specific OS metadata declared by the provider manifest."""

from __future__ import annotations

import json
import os
import sys

args = sys.argv[1:]
mode = args.pop(0) if args else ""
label = args.pop(0) if args else ""
keys = args

if mode not in {"all", "any"} or not label or not keys:
    print("validate-os: usage: validate-os <all|any> <label> <key> [key...]", file=sys.stderr)
    raise SystemExit(2)

raw_json = os.environ.get("EVE_RESOLVED_JSON") or sys.stdin.read()
resolved = json.loads(raw_json)
os_doc = resolved["os"]

def has_key(key: str) -> bool:
    return key in os_doc and str(os_doc[key]) != ""

valid = any(has_key(key) for key in keys) if mode == "any" else all(has_key(key) for key in keys)
if not valid:
    print(f"OS/provider mismatch: OS {os_doc['id']} has no {label}", file=sys.stderr)
    raise SystemExit(1)
