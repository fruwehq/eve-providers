#!/usr/bin/env python3
"""Local QEMU connectivity probe for providers-status."""
from __future__ import annotations

import json
import shutil


def main() -> None:
    if shutil.which("qemu-system-aarch64") or shutil.which("qemu-system-x86_64"):
        print(json.dumps({"configured": "yes", "reachable": "yes", "notes": "qemu available"}))
    else:
        print(json.dumps({"configured": "no", "reachable": "no", "notes": "qemu not found"}))


if __name__ == "__main__":
    main()
