#!/usr/bin/env python3
from __future__ import annotations

import hashlib
import json
import os
import shutil
import signal
import socket
import subprocess
import sys
import time
from pathlib import Path
from typing import Any

ROOT = Path(__file__).resolve().parents[4]
sys.path.insert(0, str(ROOT))

from eve_sdk.dispatch import read_resolved_from_env_or_stdin  # noqa: E402
from eve_sdk.provider_command import emit_dry_run  # noqa: E402
from eve_sdk.schema import validate_input  # noqa: E402
from eve_sdk.workdir import Workdir  # noqa: E402

PROVIDER = "local-qemu"


def run(args: list[str], *, check: bool = True, input_text: str | None = None) -> subprocess.CompletedProcess[str]:
    result = subprocess.run(args, text=True, input=input_text, capture_output=True, check=False)
    if check and result.returncode != 0:
        message = "\n".join(part for part in [result.stdout.strip(), result.stderr.strip()] if part)
        raise RuntimeError(message or f"command failed: {' '.join(args)}")
    return result


def resolved() -> dict[str, Any]:
    data = read_resolved_from_env_or_stdin()
    validate_input(data)
    if data["machine"]["provider"] != PROVIDER:
        raise RuntimeError(f"{PROVIDER} cannot handle provider {data['machine']['provider']}")
    return data


def accel() -> str:
    if sys.platform == "darwin":
        return "hvf"
    kvm = Path("/dev/kvm")
    if kvm.exists() and os.access(str(kvm), os.R_OK | os.W_OK):
        return "kvm"
    print(f"[{PROVIDER}] WARNING: no hardware acceleration (/dev/kvm absent); VM will be slow", file=sys.stderr)
    return "tcg"


def qemu_dir(instance: str) -> Path:
    return Workdir.instance_workdir(instance) / "qemu"


def metadata_path(instance: str) -> Path:
    return qemu_dir(instance) / "metadata.json"


def load_metadata(instance: str) -> dict[str, Any]:
    path = metadata_path(instance)
    if not path.exists():
        return {}
    loaded = json.loads(path.read_text(encoding="utf-8"))
    return loaded if isinstance(loaded, dict) else {}


def write_metadata(instance: str, metadata: dict[str, Any]) -> None:
    path = metadata_path(instance)
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(json.dumps(metadata, indent=2, sort_keys=True) + "\n", encoding="utf-8")


def process_running(pid: int | None) -> bool:
    if not pid:
        return False
    try:
        os.kill(pid, 0)
    except ProcessLookupError:
        return False
    except PermissionError:
        return True
    return True


def monitor_reachable(instance: str) -> bool:
    monitor = qemu_dir(instance) / "monitor.sock"
    if not monitor.exists():
        return False
    try:
        with socket.socket(socket.AF_UNIX, socket.SOCK_STREAM) as sock:
            sock.settimeout(1)
            sock.connect(str(monitor))
            return True
    except (OSError, TimeoutError):
        return False


def state_for(instance: str) -> str:
    metadata = load_metadata(instance)
    pid = metadata.get("pid")
    if process_running(pid) and monitor_reachable(instance):
        return "running"
    if (qemu_dir(instance) / "disk.qcow2").exists():
        return "stopped"
    return "absent"


def port_available(port: int) -> bool:
    with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as sock:
        sock.settimeout(0.2)
        return sock.connect_ex(("127.0.0.1", port)) != 0


def ssh_port(instance: str) -> int:
    metadata = load_metadata(instance)
    if isinstance(metadata.get("ssh_port"), int):
        return int(metadata["ssh_port"])
    digest = int(hashlib.sha256(instance.encode("utf-8")).hexdigest()[:8], 16)
    first = 2200 + digest % 40000
    for offset in range(200):
        candidate = first + offset
        if port_available(candidate):
            return candidate
    raise RuntimeError("no available localhost SSH forwarding port found")


def qemu_binary(arch: str) -> str:
    if arch != "arm64":
        raise RuntimeError(f"{PROVIDER} currently supports arm64 cloud images only (got {arch})")
    name = "qemu-system-aarch64"
    path = shutil.which(name)
    if not path:
        raise RuntimeError(f"missing {name}; install QEMU before using {PROVIDER}")
    return path


def qemu_share_dir(qemu_bin: str) -> Path:
    candidates = [
        Path(qemu_bin).resolve().parents[1] / "share/qemu",
        Path("/opt/homebrew/share/qemu"),
        Path("/usr/local/share/qemu"),
        Path("/usr/share/qemu"),
    ]
    for candidate in candidates:
        if candidate.exists():
            return candidate
    raise RuntimeError("could not locate QEMU firmware directory")


def ensure_key(instance: str) -> Path:
    key = qemu_dir(instance) / "ssh_key"
    if key.exists():
        return key
    key.parent.mkdir(parents=True, exist_ok=True)
    run(["ssh-keygen", "-q", "-t", "ed25519", "-N", "", "-f", str(key)])
    return key


def ensure_seed(instance: str, user: str) -> Path:
    key = ensure_key(instance)
    public_key = Path(f"{key}.pub").read_text(encoding="utf-8").strip()
    seed_dir = qemu_dir(instance) / "seed"
    seed_dir.mkdir(parents=True, exist_ok=True)
    (seed_dir / "meta-data").write_text(f"instance-id: {instance}\nlocal-hostname: {instance}\n", encoding="utf-8")
    user_data = "\n".join(
        [
            "#cloud-config",
            f"hostname: {instance}",
            "manage_etc_hosts: true",
            "users:",
            f"  - name: {user}",
            "    groups: [adm, sudo]",
            "    shell: /bin/bash",
            "    sudo: ALL=(ALL) NOPASSWD:ALL",
            "    lock_passwd: true",
            "    ssh_authorized_keys:",
            f"      - {public_key}",
            "ssh_pwauth: false",
            "",
        ]
    )
    (seed_dir / "user-data").write_text(user_data, encoding="utf-8")
    seed = qemu_dir(instance) / "seed.iso"
    if seed.exists():
        seed.unlink()
    if sys.platform == "darwin":
        run(
            [
                "hdiutil",
                "makehybrid",
                "-quiet",
                "-o",
                str(seed),
                "-iso",
                "-joliet",
                "-default-volume-name",
                "cidata",
                str(seed_dir),
            ]
        )
        produced = seed.with_suffix(".iso")
        if produced.exists() and produced != seed:
            produced.replace(seed)
    else:
        maker = shutil.which("cloud-localds") or shutil.which("genisoimage") or shutil.which("mkisofs")
        if not maker:
            raise RuntimeError("missing cloud-localds, genisoimage, or mkisofs for NoCloud seed generation")
        if Path(maker).name == "cloud-localds":
            run([maker, str(seed), str(seed_dir / "user-data"), str(seed_dir / "meta-data")])
        else:
            run(
                [
                    maker,
                    "-quiet",
                    "-output",
                    str(seed),
                    "-volid",
                    "cidata",
                    "-joliet",
                    "-rock",
                    str(seed_dir),
                ]
            )
    return seed


def sha256_of(path: Path) -> str:
    h = hashlib.sha256()
    with path.open("rb") as f:
        for chunk in iter(lambda: f.read(1 << 20), b""):
            h.update(chunk)
    return h.hexdigest()


def verify_checksum(path: Path, expected: str) -> None:
    actual = sha256_of(path)
    if actual != expected:
        path.unlink(missing_ok=True)
        raise RuntimeError(
            f"SHA-256 mismatch for {path.name}: expected {expected}, got {actual}\n"
            f"Corrupt download deleted. Retry or update cloud_image_sha256 in the catalog."
        )


def validate_image_metadata(data: dict[str, Any]) -> None:
    url = data["os"].get("cloud_image_url")
    if not url:
        raise RuntimeError(f"OS {data['os']['id']} has no cloud_image_url")
    sha = data["os"].get("cloud_image_sha256")
    if not sha:
        raise RuntimeError(
            f"OS {data['os']['id']} has no cloud_image_sha256; "
            f"add the SHA-256 hash to config/catalog.yaml before using {PROVIDER}"
        )


def ensure_disk(data: dict[str, Any]) -> Path:
    instance = data["instance"]["name"]
    workdir = qemu_dir(instance)
    disk = workdir / "disk.qcow2"
    if disk.exists():
        return disk
    validate_image_metadata(data)
    url = data["os"]["cloud_image_url"]
    expected_sha256 = data["os"]["cloud_image_sha256"]
    base = workdir / "base.qcow2"
    workdir.mkdir(parents=True, exist_ok=True)
    if not base.exists():
        partial = workdir / "base.qcow2.partial"
        try:
            run(["curl", "-fL", "-o", str(partial), str(url)])
            verify_checksum(partial, expected_sha256)
            os.replace(str(partial), str(base))
        except BaseException:
            partial.unlink(missing_ok=True)
            raise
    shutil.copyfile(base, disk)
    disk_gb = int(data["machine"].get("defaults", {}).get("disk_gb") or 20)
    run(["qemu-img", "resize", str(disk), f"{disk_gb}G"])
    return disk


def qemu_args(data: dict[str, Any], port: int) -> list[str]:
    instance = data["instance"]["name"]
    arch = data["os"]["arch"]
    defaults = data["machine"].get("defaults", {})
    cpus = int(defaults.get("cpu_cores") or defaults.get("cpus") or 2)
    memory_mb = int(defaults.get("memory_mb") or 4096)
    qemu = qemu_binary(arch)
    disk = ensure_disk(data)
    seed = ensure_seed(instance, data["access"]["bootstrap_user"] or "ubuntu")
    pid = qemu_dir(instance) / "qemu.pid"
    monitor = qemu_dir(instance) / "monitor.sock"
    serial = qemu_dir(instance) / "serial.sock"
    a = accel()
    args = [
        qemu,
        "-machine",
        f"virt,accel={a},highmem=on" if sys.platform == "darwin" else f"virt,accel={a}",
        "-cpu",
        "host" if a in ("hvf", "kvm") else "max",
        "-smp",
        str(cpus),
        "-m",
        str(memory_mb),
        "-device",
        "virtio-net-device,netdev=net0",
        "-netdev",
        f"user,id=net0,hostfwd=tcp::{port}-:22",
        "-drive",
        f"if=virtio,format=qcow2,file={disk}",
        "-drive",
        f"if=virtio,format=raw,media=cdrom,readonly=on,file={seed}",
        "-chardev",
        f"socket,id=mon0,path={monitor},server=on,wait=off",
        "-mon",
        "chardev=mon0,mode=readline",
        "-chardev",
        f"socket,id=ser0,path={serial},server=on,wait=off",
        "-serial",
        "chardev:ser0",
        "-pidfile",
        str(pid),
        "-daemonize",
        "-display",
        "none",
        "-parallel",
        "none",
    ]
    share = qemu_share_dir(qemu)
    code_src = share / "edk2-aarch64-code.fd"
    vars_src = share / "edk2-arm-vars.fd"
    code = qemu_dir(instance) / "edk2-aarch64-code.fd"
    vars_file = qemu_dir(instance) / "edk2-arm-vars.fd"
    if not code.exists():
        shutil.copyfile(code_src, code)
    if not vars_file.exists():
        shutil.copyfile(vars_src, vars_file)
    args.extend(
        [
            "-drive",
            f"if=pflash,format=raw,file={code},readonly=on",
            "-drive",
            f"if=pflash,format=raw,file={vars_file}",
        ]
    )
    return args


def cmd_plan(data: dict[str, Any]) -> int:
    instance = data["instance"]["name"]
    defaults = data["machine"].get("defaults", {})
    cpus = int(defaults.get("cpu_cores") or defaults.get("cpus") or 2)
    memory_mb = int(defaults.get("memory_mb") or 4096)
    disk_gb = int(defaults.get("disk_gb") or 20)
    print(f"[{PROVIDER}] instance={instance}")
    print(f"[{PROVIDER}] engine=qemu")
    print(f"[{PROVIDER}] cpus={cpus}")
    print(f"[{PROVIDER}] memory_mb={memory_mb}")
    print(f"[{PROVIDER}] disk_gb={disk_gb}")
    print(f"[{PROVIDER}] cloud_image_url={data['os'].get('cloud_image_url', '')}")
    return 0


def cmd_up(data: dict[str, Any]) -> int:
    instance = data["instance"]["name"]
    if state_for(instance) == "running":
        print(f"[{PROVIDER}] instance already running: {instance}")
        return 0
    validate_image_metadata(data)
    port = ssh_port(instance)
    args = qemu_args(data, port)
    print(f"[{PROVIDER}] starting {instance} on SSH port {port}")
    run(args)
    pid_file = qemu_dir(instance) / "qemu.pid"
    deadline = time.time() + 10
    while time.time() < deadline and not pid_file.exists():
        time.sleep(0.1)
    pid = int(pid_file.read_text(encoding="utf-8").strip()) if pid_file.exists() else None
    write_metadata(
        instance,
        {
            "pid": pid,
            "ssh_host": "127.0.0.1",
            "ssh_port": port,
            "ssh_user": data["access"]["bootstrap_user"] or "ubuntu",
            "identity_file": str(ensure_key(instance)),
        },
    )
    print(json.dumps({"status": "running"}, separators=(",", ":")))
    return 0


def graceful_stop(instance: str, pid: int) -> None:
    monitor = qemu_dir(instance) / "monitor.sock"
    if monitor.exists():
        try:
            with socket.socket(socket.AF_UNIX, socket.SOCK_STREAM) as sock:
                sock.settimeout(5)
                sock.connect(str(monitor))
                sock.sendall(b"system_powerdown\n")
                deadline = time.time() + 10
                while time.time() < deadline and process_running(pid):
                    time.sleep(0.5)
        except (OSError, TimeoutError):
            pass


def cmd_stop(data: dict[str, Any]) -> int:
    instance = data["instance"]["name"]
    metadata = load_metadata(instance)
    pid = metadata.get("pid")
    if not process_running(pid) or not monitor_reachable(instance):
        print(f"[{PROVIDER}] instance is not running: {instance}")
        print(json.dumps({"status": state_for(instance)}, separators=(",", ":")))
        return 0
    graceful_stop(instance, int(pid))
    if process_running(int(pid)):
        os.kill(int(pid), signal.SIGTERM)
    deadline = time.time() + 20
    while time.time() < deadline and process_running(int(pid)):
        time.sleep(0.5)
    if process_running(int(pid)):
        raise RuntimeError(f"failed to stop QEMU pid {pid}")
    print(json.dumps({"status": "stopped"}, separators=(",", ":")))
    return 0


def cmd_down(data: dict[str, Any]) -> int:
    instance = data["instance"]["name"]
    if state_for(instance) == "running":
        cmd_stop(data)
    target = qemu_dir(instance)
    if target.exists():
        shutil.rmtree(target)
    print(json.dumps({"status": "absent"}, separators=(",", ":")))
    return 0


def cmd_status(data: dict[str, Any]) -> int:
    instance = data["instance"]["name"]
    status = state_for(instance)
    print(f"{'Profile:':<15} {instance}")
    print(f"{'Engine:':<15} qemu")
    print(f"{'Provider:':<15} {PROVIDER}")
    print(f"{'Status:':<15} {status}")
    print(json.dumps({"status": status}, separators=(",", ":")))
    return 0


def cmd_ip(data: dict[str, Any]) -> int:
    instance = data["instance"]["name"]
    metadata = load_metadata(instance)
    if not metadata:
        raise RuntimeError(f"instance has no {PROVIDER} metadata: {instance}")
    print(metadata.get("ssh_host") or "127.0.0.1")
    return 0


def ssh_base(data: dict[str, Any]) -> list[str]:
    instance = data["instance"]["name"]
    metadata = load_metadata(instance)
    if not metadata or not (process_running(metadata.get("pid")) and monitor_reachable(instance)):
        raise RuntimeError(f"instance is not running: {instance}")
    return [
        "ssh",
        "-o",
        "StrictHostKeyChecking=no",
        "-o",
        f"UserKnownHostsFile={qemu_dir(instance) / 'known_hosts'}",
        "-o",
        "IdentitiesOnly=yes",
        "-i",
        str(metadata["identity_file"]),
        "-p",
        str(metadata["ssh_port"]),
        f"{metadata['ssh_user']}@{metadata['ssh_host']}",
    ]


def cmd_ssh(data: dict[str, Any], extra: list[str]) -> int:
    if extra and extra[0] == "--scp":
        if len(extra) != 3:
            raise RuntimeError("--scp requires <local> <remote>")
        local = Path(extra[1])
        remote = extra[2]
        if local.is_dir():
            tar = subprocess.Popen(
                ["tar", "--no-xattrs", "-C", str(local.parent), "-cf", "-", "--exclude=._*", local.name],
                stdout=subprocess.PIPE,
            )
            ssh = subprocess.Popen(
                [*ssh_base(data), f"mkdir -p '{remote}' && cd '{remote}' && tar -xf -"],
                stdin=tar.stdout,
            )
            assert tar.stdout is not None
            tar.stdout.close()
            return ssh.wait()
        with local.open("rb") as handle:
            target = f"mkdir -p '{remote}' && cat > '{remote}/{local.name}'"
            return subprocess.run([*ssh_base(data), target], stdin=handle, check=False).returncode
    if extra and extra[0] == "--":
        return os.spawnvp(os.P_WAIT, "ssh", [*ssh_base(data), " ".join(extra[1:])])
    os.execvp("ssh", ssh_base(data))
    return 1


def main(argv: list[str]) -> int:
    if not argv:
        print(f"Usage: {PROVIDER} <resolve|plan|up|start|stop|down|status|ip|ssh>", file=sys.stderr)
        return 2
    command = argv[0]
    extra = argv[1:]
    try:
        data = resolved()
        if command == "resolve" or os.environ.get("EVE_PLUGIN_DRY_RUN") == "1":
            return emit_dry_run(PROVIDER, command, data)
        if command == "plan":
            return cmd_plan(data)
        if command in {"up", "start"}:
            return cmd_up(data)
        if command == "stop":
            return cmd_stop(data)
        if command == "down":
            return cmd_down(data)
        if command == "status":
            return cmd_status(data)
        if command == "ip":
            return cmd_ip(data)
        if command == "ssh":
            return cmd_ssh(data, extra)
        raise RuntimeError(f"unsupported {PROVIDER} command: {command}")
    except Exception as error:
        print(f"{PROVIDER}: {error}", file=sys.stderr)
        return 1


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
