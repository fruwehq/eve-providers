#!/usr/bin/env python3
"""OS-portability test for raspberry-pi/lib/host-resolver.sh.

Verifies resolve_host_ip dispatches to getent on Linux, dscacheutil on macOS,
and fails clearly on an unsupported host OS. Mocks `uname` + the lookup tools on
PATH, so it exercises both branches on any single runner. Pure stdlib — no eve.
"""

from __future__ import annotations

import os
import shlex
import subprocess
import sys
import tempfile
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]
RESOLVER_HELPER = Path(
    os.environ.get("EVE_HOST_RESOLVER_HELPER", str(ROOT / "raspberry-pi/lib/host-resolver.sh"))
)
failures = 0

if not RESOLVER_HELPER.is_file():
    print(f"[FAIL] host-resolver.sh not found at {RESOLVER_HELPER}", file=sys.stderr)
    raise SystemExit(1)


def pass_check(message: str) -> None:
    print(f"  [OK] {message}")


def fail_check(message: str) -> None:
    global failures
    print(f"  [FAIL] {message}", file=sys.stderr)
    failures += 1


def write_executable(path: Path, body: str) -> None:
    path.write_text(body, encoding="utf-8")
    path.chmod(0o755)


def resolver_case(name: str, os_name: str, expected_ip: str, commands: dict[str, str]) -> None:
    with tempfile.TemporaryDirectory(prefix="eve-host-resolver.") as tmp:
        bin_dir = Path(tmp) / "bin"
        bin_dir.mkdir()
        write_executable(bin_dir / "uname", f"#!/usr/bin/env sh\nprintf '%s\\n' {shlex.quote(os_name)}\n")
        for command_name, body in commands.items():
            write_executable(bin_dir / command_name, body)
        env = os.environ | {"PATH": f"{bin_dir}:{os.environ['PATH']}"}
        script = f". {shlex.quote(str(RESOLVER_HELPER))}; resolve_host_ip {shlex.quote(name)}"
        result = subprocess.run(["bash", "-c", script], env=env, text=True, capture_output=True, check=False)
        if result.returncode == 0 and result.stdout.strip() == expected_ip:
            pass_check(f"resolve_host_ip {os_name} branch")
        else:
            fail_check(
                f"resolve_host_ip {os_name} branch expected {expected_ip!r}, "
                f"got stdout={result.stdout!r} stderr={result.stderr!r} status={result.returncode}"
            )


resolver_case(
    "raspberrypi.local",
    "Linux",
    "192.0.2.10",
    {
        "getent": "#!/usr/bin/env sh\nprintf '192.0.2.10 STREAM raspberrypi.local\\n'\n",
        "dscacheutil": "#!/usr/bin/env sh\necho 'dscacheutil should not run on Linux' >&2\nexit 99\n",
    },
)
resolver_case(
    "raspberrypi.local",
    "Darwin",
    "192.0.2.20",
    {
        "dscacheutil": "#!/usr/bin/env sh\nprintf 'name: raspberrypi.local\\nip_address: 192.0.2.20\\n'\n",
        "getent": "#!/usr/bin/env sh\necho 'getent should not run on Darwin' >&2\nexit 99\n",
    },
)

with tempfile.TemporaryDirectory(prefix="eve-host-resolver.") as tmp:
    bin_dir = Path(tmp) / "bin"
    bin_dir.mkdir()
    write_executable(bin_dir / "uname", "#!/usr/bin/env sh\nprintf '%s\\n' FreeBSD\n")
    env = os.environ | {"PATH": f"{bin_dir}:{os.environ['PATH']}"}
    script = f". {shlex.quote(str(RESOLVER_HELPER))}; resolve_host_ip raspberrypi.local"
    result = subprocess.run(["bash", "-c", script], env=env, text=True, capture_output=True, check=False)
    if result.returncode != 0 and "unsupported host OS: FreeBSD" in result.stderr:
        pass_check("resolve_host_ip rejects unsupported host OS")
    else:
        fail_check(
            f"resolve_host_ip unsupported OS expected clear failure, "
            f"got stderr={result.stderr!r} status={result.returncode}"
        )

raise SystemExit(0 if failures == 0 else 1)
